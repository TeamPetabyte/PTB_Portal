generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// One row per app in the portal catalog.
// No AppAccess rows = visible to all employees. See AppAccess below for the "A" in C+A.
model App {
  id            String   @id @default(cuid())
  name          String
  description   String
  category      String
  icon          String
  logo          String? // app logo as data URI (uploaded in Access Manager); falls back to `icon` when null
  url           String
  openInNewTab  Boolean  @default(false)
  authType      String   @default("sso") // "sso" | "own-login"
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  access     AppAccess[]
  openEvents AppOpenEvent[]

  @@map("tbl_App")
}

// Company announcements — shown in the dashboard notification feed (bell).
model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tbl_Announcement")
}

// One row per app launch — powers usage insight in Access Manager.
model AppOpenEvent {
  id        String   @id @default(cuid())
  appId     String
  userEmail String
  openedAt  DateTime @default(now())

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, openedAt])
  @@map("tbl_AppOpenEvent")
}

// Maps to an Entra ID security group. Populated once group-claim wiring (Phase 4) lands.
model AccessGroup {
  id            String   @id @default(cuid())
  name          String
  entraGroupId  String?  @unique
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  access AppAccess[]

  @@map("tbl_AccessGroup")
}

model AppAccess {
  appId   String
  groupId String

  app   App         @relation(fields: [appId], references: [id], onDelete: Cascade)
  group AccessGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([appId, groupId])
  @@map("tbl_AppAccess")
}
