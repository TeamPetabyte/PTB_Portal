# ====== Microsoft Entra ID (Azure App Registration) ======
# ได้มาจาก Azure Portal → Microsoft Entra ID → App registrations → (แอป Petabyte Portal)
MS_TENANT_ID=00000000-0000-0000-0000-000000000000      # Directory (tenant) ID ของ petabyte
MS_CLIENT_ID=00000000-0000-0000-0000-000000000000      # Application (client) ID
MS_CLIENT_SECRET=replace-with-secret-from-azure        # Certificates & secrets → New client secret (เก็บใน Secret Manager ตอน prod)

# ====== Auth.js ======
# สุ่มค่าเองด้วย: openssl rand -base64 32
AUTH_SECRET=replace-with-random-32-bytes

# URL ของแอป (ตอน dev = localhost, ตอน prod = โดเมนจริงบน Cloud Run)
AUTH_URL=http://localhost:3000

# ====== Access control (C+A) ======
# โดเมนพนักงาน (C). คั่นหลายโดเมนด้วย comma ได้
EMPLOYEE_DOMAINS=petabyte.co.th

# อีเมล owner (เห็น/จัดการแอปทั้งหมดผ่าน Access Manager). คั่นหลายคนด้วย comma ได้
OWNER_EMAILS=owner@petabyte.co.th

# ====== Database (Postgres) ======
DATABASE_URL=postgresql://user:password@host:port/dbname?schema=public
